# ──────────────────────────────────────────────────────────────────
# Meridian Crypto V6.0 — environment template
# Copy to `.env` for local dev. Never commit the real `.env`.
# ──────────────────────────────────────────────────────────────────

# Alpaca paper trading (crypto-dedicated keys)
CRYPTO_ALPACA_API_KEY=PK_YOUR_PAPER_KEY
CRYPTO_ALPACA_SECRET_KEY=YOUR_PAPER_SECRET
CRYPTO_ALPACA_PAPER=true
CRYPTO_ACCOUNT_LABEL=Ferhan Crypto Paper #1

# Generic Alpaca fallback (used if CRYPTO_* not set)
# ALPACA_API_KEY=
# ALPACA_SECRET_KEY=

# Anthropic — Sonnet 4.5 + prompt caching
ANTHROPIC_API_KEY=sk-ant-...
CRYPTO_BRAIN_MODEL=claude-sonnet-4-5-20250929

# Gemini auditor (optional — second opinion / council mode)
GEMINI_API_KEY=

# Auto-executor (default OFF — set true only after smoke testing in prod)
CRYPTO_AUTO_EXECUTE=false
CRYPTO_DRY_RUN=true

# Admin guard — when set, /api/crypto/run-now POST requires
# `X-Admin-Token` header equal to this value. Mandatory in production.
CRYPTO_ADMIN_TOKEN=

# Journal persistence path (Railway: mount /app/data volume here)
JOURNAL_DB_PATH=/app/data/crypto_journal.db
